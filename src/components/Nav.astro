---
const CALENDLY = 'https://calendly.com/jt-adlard/30min';
const links = [
  { label: 'Services', href: '/#services' },
  { label: 'For Contractors', href: '/construction/' },
  { label: 'AI', href: '/ai/' },
  { label: 'About', href: '/#about' },
];
const path = Astro.url.pathname;
---

<header class="nav" id="site-nav">
  <div class="container nav__inner">
    <a href="/" class="nav__brand" aria-label="Atomic CFO home">
      <svg width="30" height="30" viewBox="0 0 40 40" fill="none" aria-hidden="true">
        <rect x="3" y="28" width="3" height="3" fill="#C8963E" opacity="0.5"/>
        <rect x="7" y="25" width="3" height="3" fill="#C8963E" opacity="0.6"/>
        <rect x="11" y="27" width="2.5" height="2.5" fill="#C8963E" opacity="0.7"/>
        <rect x="10" y="22" width="4" height="12" rx="0.5" fill="#1B2A4A"/>
        <rect x="16" y="18" width="4" height="16" rx="0.5" fill="#1B2A4A"/>
        <rect x="22" y="14" width="4" height="20" rx="0.5" fill="#1B2A4A"/>
        <rect x="28" y="8" width="4" height="26" rx="0.5" fill="#1B2A4A"/>
        <path d="M8 26L30 6" stroke="#1B2A4A" stroke-width="2" stroke-linecap="round"/>
        <path d="M24 5L31 5.5L30.5 12.5" stroke="#1B2A4A" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      <span class="nav__wordmark">ATOMIC CFO</span>
    </a>

    <nav class="nav__links" aria-label="Primary">
      {links.map((l) => (
        <a href={l.href} class:list={['nav__link', { 'is-active': path === l.href }]}>{l.label}</a>
      ))}
      <a href={CALENDLY} class="btn btn--gold nav__cta">Book a call</a>
    </nav>

    <button class="nav__toggle" aria-expanded="false" aria-controls="mobile-menu" aria-label="Menu">
      <span></span><span></span><span></span>
    </button>
  </div>

  <div class="nav__mobile" id="mobile-menu" hidden>
    {links.map((l) => <a href={l.href} class="nav__mlink">{l.label}</a>)}
    <a href={CALENDLY} class="btn btn--gold" style="justify-content:center">Book a call</a>
  </div>
</header>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(248, 247, 244, 0.92);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--warm-gray-light);
  }
  .nav__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 14px;
    padding-bottom: 14px;
  }
  .nav__brand {
    display: flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
  }
  .nav__wordmark {
    font-family: var(--sans);
    font-weight: 700;
    font-size: 0.9375rem;
    letter-spacing: 0.16em;
    color: var(--navy);
    border-bottom: 2px solid var(--gold);
    padding-bottom: 2px;
  }
  .nav__links {
    display: flex;
    align-items: center;
    gap: 28px;
  }
  .nav__link {
    font-size: var(--text-small);
    font-weight: 600;
    color: var(--slate);
    text-decoration: none;
    transition: color 0.2s;
  }
  .nav__link:hover, .nav__link.is-active { color: var(--navy); }
  .nav__cta { padding: 11px 22px; font-size: 0.9375rem; }

  .nav__toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px;
  }
  .nav__toggle span {
    width: 22px;
    height: 2px;
    background: var(--navy);
    border-radius: 2px;
  }

  .nav__mobile {
    flex-direction: column;
    gap: 4px;
    padding: 12px 24px 22px;
    border-top: 1px solid var(--warm-gray-light);
    background: var(--offwhite);
  }
  .nav__mobile:not([hidden]) { display: flex; }
  .nav__mlink {
    padding: 12px 4px;
    font-size: 1.0625rem;
    font-weight: 600;
    color: var(--navy);
    text-decoration: none;
    border-bottom: 1px solid var(--warm-gray-light);
  }
  .nav__mobile .btn { margin-top: 14px; }

  @media (max-width: 820px) {
    .nav__links { display: none; }
    .nav__toggle { display: flex; }
  }
</style>

<script>
  const toggle = document.querySelector('.nav__toggle');
  const menu = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => {
    const open = toggle.getAttribute('aria-expanded') === 'true';
    toggle.setAttribute('aria-expanded', String(!open));
    if (menu) menu.hidden = open;
  });
  menu?.addEventListener('click', (e) => {
    if ((e.target as HTMLElement).tagName === 'A') {
      menu.hidden = true;
      toggle?.setAttribute('aria-expanded', 'false');
    }
  });
</script>
